{
	"schemaVersion": 1,
	"id": "agritech",
	"version": "${version}",
	"name": "Agritech",
	"description": "Agritech introduces planters, raised beds and crates to help with crop and sapling automation.",
	"authors": [
		"MisterD Modding"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "MIT",
	"icon": "assets/agritech/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.misterd.agritech.Agritech"
		],
		"client": [
			"com.misterd.agritech.AgritechClient"
		],
		"fabric-datagen": [
			"com.misterd.agritech.AgritechDataGenerator"
		],
		"jade": [
			"com.misterd.agritech.compat.jade.ATJadePlugin"
		],
		"jei_mod_plugin": [
			"com.misterd.agritech.compat.jei.ATJeiPlugin"
		]
	},
	"mixins": [
		"agritech.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}